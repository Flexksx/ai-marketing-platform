{
	"name": "spa",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:local": "dotenv -e .env.local -- vite dev",
		"dev:prod": "dotenv -e .env.production -- vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format:check": "biome format --check .",
		"format:write": "biome format --write .",
		"lint:check": "biome lint .",
		"lint:write": "biome lint . --write",
		"verify:check": "pnpm run check && pnpm run format:check && pnpm run lint:check",
		"verify:write": "pnpm run format:write && pnpm run lint:write",
		"generate:api": "bash scripts/generate-api.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@openapitools/openapi-generator-cli": "2.32.0",
		"@inlang/paraglide-js": "^2.4.0",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/adapter-node": "^5.2.12",
		"@sveltejs/kit": "^2.59.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.14",
		"@types/node": "^22.18.11",
		"bits-ui": "^2.14.4",
		"clsx": "^2.1.1",
		"dotenv-cli": "^8.0.0",
		"svelte": "^5.53.1",
		"svelte-check": "^4.4.3",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.14",
		"tw-animate-css": "^1.4.0",
		"typescript": "5.9.3",
		"vite": "^8.0.10",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"@supabase/ssr": "^0.7.0",
		"@supabase/supabase-js": "^2.75.0",
		"@tanstack/svelte-query": "^6.0.18",
		"axios": "^1.13.2",
		"lucide-svelte": "^0.554.0",
		"marked": "^17.0.1",
		"nanoid": "^5.1.6",
		"svelte-awesome-color-picker": "^4.0.2"
	}
}
