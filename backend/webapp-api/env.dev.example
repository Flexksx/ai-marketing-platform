# Local Development Environment Variables
# Copy this to .env for local development

# Local PostgreSQL (from docker-compose-dev.yaml)
DATABASE_URL=postgresql://vozai:vozai_dev_password@localhost:5433/vozai_dev
DIRECT_URL=postgresql://vozai:vozai_dev_password@localhost:5433/vozai_dev

# Supabase (still needed for auth - use your dev/staging project)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx

# OpenAI API Key
OPENAI_API_KEY=sk-xxxx

# Google Gemini — used for AI image generation
GOOGLE_CLOUD_SERVICES_API_KEY=xxxx
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# GCP Settings (for local dev, these are mocked)
GCP_PROJECT_ID=local-dev
GCP_LOCATION=local
CLOUD_TASKS_QUEUE=local-campaign-queue
WORKER_SERVICE_URL=http://localhost:8001
WORKER_SERVICE_ACCOUNT_EMAIL=local@dev.local

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG
