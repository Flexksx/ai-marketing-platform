{
  "uid": "vozai-services",
  "title": "Voz AI \u2014 Observability Overview",
  "tags": ["vozai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Container Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 2,
      "title": "CPU Usage %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 12 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"webapp-api|scraper-api|db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket|vector|loki|prometheus|grafana\",name!=\"\"}[1m]))) * 100",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Memory Usage",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 12 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"webapp-api|scraper-api|db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket|vector|loki|prometheus|grafana\",name!=\"\"}))",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Running Instances",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count by (container_label_com_docker_compose_service) (group by (name, container_label_com_docker_compose_service) (container_memory_usage_bytes{container_label_com_docker_compose_service=~\"webapp-api|scraper-api|db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket|vector|loki|prometheus|grafana\",name!=\"\"}))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "instant": true
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Network I/O",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=~\"webapp-api|scraper-api|db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket|vector|loki|prometheus|grafana\",name!=\"\"}[1m])))",
          "legendFormat": "{{container_label_com_docker_compose_service}} rx"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=~\"webapp-api|scraper-api|db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket|vector|loki|prometheus|grafana\",name!=\"\"}[1m])))",
          "legendFormat": "{{container_label_com_docker_compose_service}} tx"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Log Volume by Service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (rate({service=~\"webapp-api|scraper-api|db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket|vector|loki|prometheus|grafana\"}[1m]))"
        }
      ]
    },
    {
      "type": "row",
      "id": 10,
      "title": "Host Resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "type": "gauge",
      "id": 11,
      "title": "Host CPU %",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU",
          "instant": true
        }
      ]
    },
    {
      "type": "gauge",
      "id": 12,
      "title": "Host Memory %",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory",
          "instant": true
        }
      ]
    },
    {
      "type": "gauge",
      "id": 13,
      "title": "Host Disk %",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "Disk /",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 20,
      "title": "HTTP Requests",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name) (rate(vozai_http_server_request_duration_seconds_count{service_name=~\"webapp-api|scraper-api\"}[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "Status Code Split",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name, http_response_status_code) (rate(vozai_http_server_request_duration_seconds_count{service_name=~\"webapp-api|scraper-api\"}[5m]))",
          "legendFormat": "{{service_name}} {{http_response_status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 23,
      "title": "Error Rate (5xx / total)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name) (rate(vozai_http_server_request_duration_seconds_count{http_response_status_code=~\"5..\",service_name=~\"webapp-api|scraper-api\"}[1m])) / sum by (service_name) (rate(vozai_http_server_request_duration_seconds_count{service_name=~\"webapp-api|scraper-api\"}[1m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 24,
      "title": "Request Duration p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (service_name, le) (rate(vozai_http_server_request_duration_seconds_bucket{service_name=~\"webapp-api|scraper-api\"}[5m])))",
          "legendFormat": "{{service_name}} p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (service_name, le) (rate(vozai_http_server_request_duration_seconds_bucket{service_name=~\"webapp-api|scraper-api\"}[5m])))",
          "legendFormat": "{{service_name}} p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (service_name, le) (rate(vozai_http_server_request_duration_seconds_bucket{service_name=~\"webapp-api|scraper-api\"}[5m])))",
          "legendFormat": "{{service_name}} p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 25,
      "title": "5xx Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (service_name) (rate(vozai_http_server_request_duration_seconds_count{http_response_status_code=~\"5..\",service_name=~\"webapp-api|scraper-api\"}[5m]))",
          "legendFormat": "{{service_name}}"
        }
      ]
    },
    {
      "type": "row",
      "id": 30,
      "title": "Logs",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 31,
      "title": "Error Logs by Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (rate({service=~\"webapp-api|scraper-api\"} | json | severity=~\"ERROR|CRITICAL|FATAL\" [5m]))"
        }
      ]
    },
    {
      "type": "bargauge",
      "id": 32,
      "title": "Error Log Count (5m)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({service=~\"webapp-api|scraper-api\"} | json | severity=~\"ERROR|CRITICAL|FATAL\" [5m]))"
        }
      ]
    },
    {
      "type": "row",
      "id": 40,
      "title": "Pipeline Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 50 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 41,
      "title": "Prometheus Target Health",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (job) (up{job=~\"vector|loki|cadvisor|node-exporter\"})",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 42,
      "title": "Vector Events Throughput",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (component_id) (rate(vector_component_received_events_total[5m]))",
          "legendFormat": "{{component_id}} in"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (component_id) (rate(vector_component_sent_events_total[5m]))",
          "legendFormat": "{{component_id}} out"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 43,
      "title": "Vector Errors",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 51 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (component_id) (rate(vector_component_errors_total[5m]))",
          "legendFormat": "{{component_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 44,
      "title": "Vector Utilization",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 59 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (component_id) (vector_utilization{component_id=~\"docker_logs|docker_logs_normalized|otlp|loki|prometheus_exporter\"})",
          "legendFormat": "{{component_id}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 45,
      "title": "Scrape Duration",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 59 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (job) (scrape_duration_seconds{job=~\"vector|loki|cadvisor|node-exporter\"})",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
