{
  "uid": "vozai-supabase",
  "title": "Voz AI \u2014 Supabase (dev)",
  "tags": ["vozai", "supabase"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Containers (cAdvisor)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 2,
      "title": "CPU %",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 12 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket\",name!=\"\"}[1m]))) * 100",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Memory (working set)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 12 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket\",name!=\"\"}))",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Running containers",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count by (container_label_com_docker_compose_service) (group by (name, container_label_com_docker_compose_service) (container_memory_usage_bytes{container_label_com_docker_compose_service=~\"db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket\",name!=\"\"}))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 10,
      "title": "Network",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Network I/O",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=~\"db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket\",name!=\"\"}[1m])))",
          "legendFormat": "{{container_label_com_docker_compose_service}} rx"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (container_label_com_docker_compose_service) (max by (name, container_label_com_docker_compose_service) (rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=~\"db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket\",name!=\"\"}[1m])))",
          "legendFormat": "{{container_label_com_docker_compose_service}} tx"
        }
      ]
    },
    {
      "type": "row",
      "id": 20,
      "title": "Logs (Vector \u2192 Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 21,
      "title": "Log lines / s by service",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (rate({service=~\"db|kong|auth|rest|storage|studio|meta|imgproxy|inbucket\"}[1m]))"
        }
      ]
    }
  ]
}
