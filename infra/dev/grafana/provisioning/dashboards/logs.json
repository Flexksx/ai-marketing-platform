{
  "uid": "vozai-logs",
  "title": "Voz AI \u2014 Logs",
  "tags": ["vozai"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(service)",
        "query": "label_values(service)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {}
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Level",
        "query": "debug,info,warning,error",
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "search",
        "type": "textbox",
        "label": "Search",
        "query": "",
        "current": {}
      }
    ]
  },
  "panels": [

    {
      "type": "text",
      "id": 100,
      "title": "Common LogQL queries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "### Quick reference — click any panel's ⋮ menu → **Explore** to open the query directly\n\n| Intent | LogQL |\n|---|---|\n| All backend logs | `{service=~\"webapp-api\\|scraper-api\"}` |\n| Errors only | `{service=~\"webapp-api\\|scraper-api\"} \\| json \\| level=\"error\"` |\n| By trace ID | `{service=\"webapp-api\"} \\| json \\| trace_id=\"<id>\"` |\n| Route filter | `{service=\"webapp-api\"} \\| json \\|~ \"/brands\"` |\n| Slow requests (>1s) | `{service=\"webapp-api\"} \\| json \\| duration > 1s` |\n| Count errors / 5m | `sum by (service) (count_over_time({service=~\"webapp-api\\|scraper-api\"} \\| json \\| level=\"error\" [5m]))` |\n| Rate of all logs | `sum by (service) (rate({service=~\"webapp-api\\|scraper-api\"}[1m]))` |\n| Postgres errors | `{service=\"postgres\"} \\|~ \"(?i)error\\|fatal\"` |"
      }
    },

    {
      "type": "row",
      "id": 1,
      "title": "webapp-api",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false
    },

    {
      "type": "logs",
      "id": 2,
      "title": "webapp-api logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"webapp-api\"} | json | level=~\"$level\" |~ \"$search\""
        }
      ]
    },

    {
      "type": "row",
      "id": 10,
      "title": "scraper-api",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },

    {
      "type": "logs",
      "id": 11,
      "title": "scraper-api logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"scraper-api\"} | json | level=~\"$level\" |~ \"$search\""
        }
      ]
    },

    {
      "type": "row",
      "id": 20,
      "title": "postgres",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "collapsed": true,
      "panels": [
        {
          "type": "logs",
          "id": 21,
          "title": "postgres logs",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
          "datasource": { "type": "loki", "uid": "loki" },
          "options": {
            "dedupStrategy": "none",
            "enableLogDetails": true,
            "showTime": true,
            "showLabels": false,
            "wrapLogMessage": false,
            "sortOrder": "Descending"
          },
          "targets": [
            {
              "refId": "A",
              "datasource": { "type": "loki", "uid": "loki" },
              "expr": "{service=\"postgres\"} |~ \"$search\""
            }
          ]
        }
      ]
    }

  ]
}
